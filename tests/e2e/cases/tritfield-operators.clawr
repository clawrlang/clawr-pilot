const a = tritfield("0?1")
const b = tritfield("1?0")

const c = a & b
const d = a | b

const rot = rotate(a, by: b)
const adj = adjust(a, towards: b)
const mod = modulate(a, by: b)

const rotIdentity = rotate(a, by: tritfield("???"))
const adjIdentity = adjust(a, towards: tritfield("???"))
const modKeep = modulate(a, by: tritfield("111"))
const modClear = modulate(a, by: tritfield("???"))

print(a.toString())
print(b.toString())
print(c.toString())
print(d.toString())
print(rot.toString())
print(adj.toString())
print(mod.toString())
print(rotIdentity.toString())
print(adjIdentity.toString())
print(modKeep.toString())
print(modClear.toString())
