const f = false
const a = ambiguous
const t = true

print(adjust(f, towards: t))
print(adjust(t, towards: f))
print(a.adjust(towards: t))

print(rotate(f, by: t))
print(rotate(f, by: a))
print(rotate(f, by: f))

print(a.rotateUp())
print(a.rotateDown())
print(a.rotate(by: t))
print(a.rotate(by: f))

// identity: ambiguous direction = no change
print(adjust(f, towards: a))
print(adjust(t, towards: a))
print(adjust(a, towards: a))

// clamping at extremes
print(adjust(f, towards: f))
print(adjust(t, towards: t))
