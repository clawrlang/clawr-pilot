const f = false
const a = ambiguous
const t = true

print(adjustUp(a))
print(adjustDown(a))

print(adjust(f, towards: t))
print(adjust(t, towards: f))
print(adjust(a, towards: t))

print(rotate(f, by: t))
print(rotate(f, by: a))
print(rotate(f, by: f))

print(rotateUp(a))
print(rotateDown(a))
print(rotate(a, by: t))
print(rotate(a, by: f))

// identity: ambiguous direction = no change
print(adjust(f, towards: a))
print(adjust(t, towards: a))
print(adjust(a, towards: a))

// clamping at extremes
print(adjust(f, towards: f))
print(adjust(t, towards: t))
