rotate(false, by: true): ambiguous
rotate(ambiguous, by: true): true
rotate(true, by: true): false
rotate(false, by: false): true
rotate(ambiguous, by: false): false
rotate(true, by: false): ambiguous
adjust(false, towards: true): ambiguous
adjust(true, towards: true): true
adjust(true, towards: false): ambiguous
adjust(ambiguous, towards: false): false
modulate(false, by: false): true
modulate(false, by: ambiguous): ambiguous
modulate(false, by: true): false
modulate(ambiguous, by: true): ambiguous
modulate(true, by: true): true
modulate(true, by: false): false
